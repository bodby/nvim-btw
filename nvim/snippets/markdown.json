{
  "note-metadata": {
    "prefix": "note-metadata",
    "body": [
      "---",
      "aliases:",
      "\t- \"${1:Title}\"",
      "---",
      "",
      "# ${1:Title}",
      "$0"
    ]
  },

  "blog-metadata": {
    "prefix": "blog-metadata",
    "body": [
      "---",
      "title: \"${1:Title}\"",
      "abstract: \"${2:Short description}\"",
      "date: ${3:YYYY-MM-DD}",
      "---",
      "",
      "# ${1:Title}",
      "$0"
    ]
  },

  "link": {
    "prefix": "link",
    "body": "[${1:text}](https://${2:url})"
  },

  "code": {
    "prefix": "code",
    "body": [
      "```${1:text}",
      "$0",
      "```"
    ]
  }
}
