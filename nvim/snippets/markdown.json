{
  "metadata": {
    "prefix": "yaml-aliases-metadata",
    "body": [
      "---",
      "aliases:",
      "\t- \"${1:Title}\"",
      "---",
      "",
      "# ${1:Title}",
      "$0"
    ]
  },

  "todo": {
    "prefix": "todo",
    "body": "- [ ] $0"
  },

  "link": {
    "prefix": "link",
    "body": "[${1:text}](https://${2:url})"
  },

  "code": {
    "prefix": "code",
    "body": [
      "```${1:text}",
      "$0",
      "```"
    ]
  }
}
